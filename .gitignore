# SwapMaster V1 - Git Ignore

# Ignore everything by default
*

# === ALLOW: Documentation & Config ===
!.gitignore
!.env.example
!.env
!README.md
!SETTINGS_USED.md
!GPU Configuration Knowledge.md
!Settings Used in This Project.md
!MIGRATION_REPORT.md
!MASTER_SETUP_PROMPT.md
!normalization output name fix.md
!auto_setup.sh
!setup_auto.sh
!setup.sh
!setup.bat
!run.sh
!run.bat
!requirements.txt
!.config/
!.config/rclone/
!.config/rclone/rclone.conf

# === ALLOW: App source code ===
!app/
!app/*.py
!app/ops/
!app/ops/*.py
!app/config/
!app/config/*.json
!app/persistent/
!app/persistent/*.json
!app/facefusion/
!app/facefusion/*.py
!app/facefusion/facefusion/
!app/facefusion/facefusion/*.py
!app/facefusion/facefusion/core/
!app/facefusion/facefusion/core/*.py
!app/facefusion/facefusion/modules/
!app/facefusion/facefusion/modules/*.py
!app/facefusion/facefusion/inference/
!app/facefusion/facefusion/inference/*.py
!app/facefusion/facefusion/inference_manager.py
!app/facefusion/facefusion/globals.py
!app/facefusion/facefusion/utilities/
!app/facefusion/facefusion/utilities/*.py
!app/pipeline/
!app/pipeline/*.py

# === ALLOW: GitHub ===
!.github/
!.github/workflows/
!.github/workflows/*.yml

# === DENY: Large files & cache ===
*.pyc
__pycache__/
*.pth
*.onnx
*.dat
*.bin
*.pt
*.mp4
*.avi
*.mov
*.mkv
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.log
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db
node_modules/
.ngrok/
.local/
models/
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.env.local
.env.production
.env
